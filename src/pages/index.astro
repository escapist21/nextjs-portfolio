---
import BaseLayout from '../layouts/BaseLayout.astro'
import BlogPostList from '../components/BlogPostList.astro'
import SocialLinks from '../components/SocialLinks.astro'
---
<BaseLayout>
  <section class="flex flex-col lg:flex-row space-y-6 md:space-y-10 lg:space-y-0 lg:space-x-16">
    <div class="flex w-full lg:w-1/3 flex-col rounded-2xl border-6 border-emerald-500 py-10 px-4" id="Social Section">
      <div class="flex justify-center">
        <img
          class="mb-4 rounded-lg object-cover"
          src="/images/headshot.webp"
          alt="A profile image of Sourav Adhikari"
          width="240"
          height="280"
          loading="eager"
          fetchpriority="high"
        />
      </div>
      <div class="flex flex-col">
        <h3 class="mb-4 text-center text-3xl md:text-4xl lg:text-5xl font-extrabold font-stretch-condensed tracking-tight">Sourav Adhikari</h3>
        <p class="text-center text-md lg:text-md font-stretch-extra-condensed">Data Scientist | Systems Thinker | Researcher</p>
        <p class="text-center text-md lg:text-md">New Delhi, India</p>
        <SocialLinks />
      </div>
    </div>
    <div class="flex flex-col w-full lg:w-2/3 text-center lg:text-left justify-center md:justify-start" id="Main Content">
      <h1 class="text-2xl sm:text-3xl md:text-5xl lg:text-6xl font-extrabold font-stretch-50% tracking-tight">
        Building AI &amp; Data Tools for
      </h1>
      <h1 class="mb-4 text-3xl sm:text-4xl md:text-6xl lg:text-7xl font-extrabold text-emerald-500">
        Policy Impact
      </h1>
      <p class="mb-4 text-base lg:text-xl">Data Science enthusiast working at the intersection of public policy, systems design and social impact</p>
      <div class="my-8">
        <h1 class="text-4xl lg:text-5xl font-extrabold font-stretch-50% tracking-tight mb-6">
          Thoughts
        </h1>
        <BlogPostList />
      </div>
    </div>
  </section>
</BaseLayout>
